{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Clear Board",
  "mainBinaryName": "Clear Board",
  "version": "0.1.0",
  "identifier": "com.observatory.clear-board",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:4548",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Clear Board",
        "width": 1040,
        "height": 840,
        "minWidth": 600,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#0e1116"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
